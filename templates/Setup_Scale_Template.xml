<?xml version="1.0" encoding="UTF-8" ?>
<OpenSimDocument Version="40000">
	<ScaleTool name="scale_tool">
		<mass>75</mass>
		<notes>Template de Scale para o pipeline de marcha. Ajuste mass e caminhos conforme o sujeito.</notes>

		<GenericModelMaker>
			<model_file>C:\Users\paulo\Modelos_OpenSim_Teste\FBLSmodel_markers_limpo.osim</model_file>
			<marker_set_file>Unassigned</marker_set_file>
		</GenericModelMaker>

		<ModelScaler>
			<apply>true</apply>
			<scaling_order> measurements </scaling_order>
			<MeasurementSet>
				<objects>

					<!-- ========== PELVE ========== -->
					<Measurement name="pelvis_width">
						<apply>true</apply>
						<MarkerPairSet>
							<objects>
								<MarkerPair>
									<markers> R.ASIS L.ASIS </markers>
								</MarkerPair>
							</objects>
						</MarkerPairSet>
						<BodyScaleSet>
							<objects>
								<BodyScale name="pelvis">
									<axes> X Y Z </axes>
								</BodyScale>
								<BodyScale name="sacrum">
									<axes> X Y Z </axes>
								</BodyScale>
							</objects>
						</BodyScaleSet>
					</Measurement>

					<!-- ========== FEMUR DIREITO ========== -->
					<Measurement name="femur_r">
						<apply>true</apply>
						<MarkerPairSet>
							<objects>
								<MarkerPair>
									<markers> R.ASIS R.Knee </markers>
								</MarkerPair>
							</objects>
						</MarkerPairSet>
						<BodyScaleSet>
							<objects>
								<BodyScale name="femur_r">
									<axes> X Y Z </axes>
								</BodyScale>
								<BodyScale name="patella_r">
									<axes> X Y Z </axes>
								</BodyScale>
							</objects>
						</BodyScaleSet>
					</Measurement>

					<!-- ========== FEMUR ESQUERDO ========== -->
					<Measurement name="femur_l">
						<apply>true</apply>
						<MarkerPairSet>
							<objects>
								<MarkerPair>
									<markers> L.ASIS L.Knee </markers>
								</MarkerPair>
							</objects>
						</MarkerPairSet>
						<BodyScaleSet>
							<objects>
								<BodyScale name="femur_l">
									<axes> X Y Z </axes>
								</BodyScale>
								<BodyScale name="patella_l">
									<axes> X Y Z </axes>
								</BodyScale>
							</objects>
						</BodyScaleSet>
					</Measurement>

					<!-- ========== TIBIA DIREITA ========== -->
					<Measurement name="tibia_r">
						<apply>true</apply>
						<MarkerPairSet>
							<objects>
								<MarkerPair>
									<markers> R.Knee R.Ankle </markers>
								</MarkerPair>
							</objects>
						</MarkerPairSet>
						<BodyScaleSet>
							<objects>
								<BodyScale name="tibia_r">
									<axes> X Y Z </axes>
								</BodyScale>
								<BodyScale name="talus_r">
									<axes> X Y Z </axes>
								</BodyScale>
								<BodyScale name="calcn_r">
									<axes> X Y Z </axes>
								</BodyScale>
								<BodyScale name="toes_r">
									<axes> X Y Z </axes>
								</BodyScale>
							</objects>
						</BodyScaleSet>
					</Measurement>

					<!-- ========== TIBIA ESQUERDA ========== -->
					<Measurement name="tibia_l">
						<apply>true</apply>
						<MarkerPairSet>
							<objects>
								<MarkerPair>
									<markers> L.Knee L.Ankle </markers>
								</MarkerPair>
							</objects>
						</MarkerPairSet>
						<BodyScaleSet>
							<objects>
								<BodyScale name="tibia_l">
									<axes> X Y Z </axes>
								</BodyScale>
								<BodyScale name="talus_l">
									<axes> X Y Z </axes>
								</BodyScale>
								<BodyScale name="calcn_l">
									<axes> X Y Z </axes>
								</BodyScale>
								<BodyScale name="toes_l">
									<axes> X Y Z </axes>
								</BodyScale>
							</objects>
						</BodyScaleSet>
					</Measurement>



				</objects>
			</MeasurementSet>
			<marker_file>C:\Users\paulo\Modelos_OpenSim_Teste\Gait Dataset\TRC_Output\static.trc</marker_file>
			<time_range> 0.5 1.5 </time_range>
			<preserve_mass_distribution>true</preserve_mass_distribution>
			<output_model_file>C:\Users\paulo\Modelos_OpenSim_Teste\subject_scaled.osim</output_model_file>
			<output_scale_file>C:\Users\paulo\Modelos_OpenSim_Teste\subject_scale_factors.xml</output_scale_file>
		</ModelScaler>

		<MarkerPlacer>
			<apply>true</apply>
			<IKTaskSet>
				<objects>
					<!-- Anatomicos (peso alto) -->
					<IKMarkerTask name="R.ASIS"><apply>true</apply><weight>10</weight></IKMarkerTask>
					<IKMarkerTask name="L.ASIS"><apply>true</apply><weight>10</weight></IKMarkerTask>
					<IKMarkerTask name="R.PSIS"><apply>true</apply><weight>10</weight></IKMarkerTask>
					<IKMarkerTask name="L.PSIS"><apply>true</apply><weight>10</weight></IKMarkerTask>
					<IKMarkerTask name="R.Knee"><apply>true</apply><weight>10</weight></IKMarkerTask>
					<IKMarkerTask name="L.Knee"><apply>true</apply><weight>10</weight></IKMarkerTask>
					<IKMarkerTask name="R.Knee.Med"><apply>true</apply><weight>10</weight></IKMarkerTask>
					<IKMarkerTask name="L.Knee.Med"><apply>true</apply><weight>10</weight></IKMarkerTask>
					<IKMarkerTask name="R.Ankle"><apply>true</apply><weight>10</weight></IKMarkerTask>
					<IKMarkerTask name="L.Ankle"><apply>true</apply><weight>10</weight></IKMarkerTask>
					<IKMarkerTask name="R.Ankle.Med"><apply>true</apply><weight>10</weight></IKMarkerTask>
					<IKMarkerTask name="L.Ankle.Med"><apply>true</apply><weight>10</weight></IKMarkerTask>
					<IKMarkerTask name="R.Heel"><apply>true</apply><weight>10</weight></IKMarkerTask>
					<IKMarkerTask name="L.Heel"><apply>true</apply><weight>10</weight></IKMarkerTask>
					<IKMarkerTask name="R.MT1"><apply>true</apply><weight>10</weight></IKMarkerTask>
					<IKMarkerTask name="L.MT1"><apply>true</apply><weight>10</weight></IKMarkerTask>
					<IKMarkerTask name="R.MT5"><apply>true</apply><weight>10</weight></IKMarkerTask>
					<IKMarkerTask name="L.MT5"><apply>true</apply><weight>10</weight></IKMarkerTask>
					<!-- Tracking (peso baixo) -->
					<IKMarkerTask name="R.THIGH"><apply>true</apply><weight>1</weight></IKMarkerTask>
					<IKMarkerTask name="L.THIGH"><apply>true</apply><weight>1</weight></IKMarkerTask>
					<IKMarkerTask name="R.FIB"><apply>true</apply><weight>1</weight></IKMarkerTask>
					<IKMarkerTask name="L.FIB"><apply>true</apply><weight>1</weight></IKMarkerTask>
					<IKMarkerTask name="R.TIB"><apply>true</apply><weight>1</weight></IKMarkerTask>
					<IKMarkerTask name="L.TIB"><apply>true</apply><weight>1</weight></IKMarkerTask>
					<!-- Marcadores do modelo sem correspondente no TRC (desligados) -->
					<IKMarkerTask name="R.GTR"><apply>false</apply><weight>0</weight></IKMarkerTask>
					<IKMarkerTask name="L.GTR"><apply>false</apply><weight>0</weight></IKMarkerTask>
					<IKMarkerTask name="R.HF"><apply>false</apply><weight>0</weight></IKMarkerTask>
					<IKMarkerTask name="L.HF"><apply>false</apply><weight>0</weight></IKMarkerTask>
					<IKMarkerTask name="R.TT"><apply>false</apply><weight>0</weight></IKMarkerTask>
					<IKMarkerTask name="L.TT"><apply>false</apply><weight>0</weight></IKMarkerTask>
				</objects>
			</IKTaskSet>
			<marker_file>C:\Users\paulo\Modelos_OpenSim_Teste\Gait Dataset\TRC_Output\static.trc</marker_file>
			<time_range> 0.5 1.5 </time_range>
			<output_model_file>C:\Users\paulo\Modelos_OpenSim_Teste\subject_scaled.osim</output_model_file>
			<output_motion_file>C:\Users\paulo\Modelos_OpenSim_Teste\subject_static_output.mot</output_motion_file>
			<max_marker_movement>-1</max_marker_movement>
		</MarkerPlacer>

	</ScaleTool>
</OpenSimDocument>
